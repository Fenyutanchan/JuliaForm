Cell[CellGroupData[{
Cell["Properties and relations", "ExampleSection", CellID -> 1000059],

Cell["The two string-producing forms are equivalent:", "ExampleText",
    CellID -> 1000060],

Cell[CellGroupData[{
Cell[BoxData[
    RowBox[{
        RowBox[{
            "ToString", "[",
            RowBox[{
                RowBox[{
                    "HoldForm", "[",
                    RowBox[{
                        "a", "/",
                        RowBox[{"(", RowBox[{"b", "+", "c"}], ")"}]
                    }],
                    "]"
                }],
                ",", "JuliaForm"
            }],
            "]"
        }],
        "===",
        RowBox[{
            "ToString", "[",
            RowBox[{
                RowBox[{
                    "JuliaForm", "[",
                    RowBox[{
                        "HoldForm", "[",
                        RowBox[{
                            "a", "/",
                            RowBox[{"(", RowBox[{"b", "+", "c"}], ")"}]
                        }],
                        "]"
                    }],
                    "]"
                }],
                ",", "OutputForm"
            }],
            "]"
        }]
    }]
], "Input", CellLabel -> "In[11]:=", CellID -> 1000061],
Cell[BoxData["True"], "Output",
    CellLabel -> "Out[11]=", CellID -> 1000062]
}, Open]],

