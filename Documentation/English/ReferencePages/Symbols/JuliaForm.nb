Cell["Render a held quotient while preserving its parentheses:", "ExampleText",
    CellID -> 1000028],

Cell[CellGroupData[{
Cell[BoxData[
    RowBox[{
        "ToString", "[",
        RowBox[{
            RowBox[{
                "JuliaForm", "[",
                RowBox[{
                    "HoldForm", "[",
                    RowBox[{
                        "a", "/",
                        RowBox[{"(", RowBox[{"b", "+", "c"}], ")"}]
                    }],
                    "]"
                }],
                "]"
            }],
            ",", "OutputForm"
        }],
        "]"
    }]
], "Input", CellLabel -> "In[2]:=", CellID -> 1000029],
Cell[BoxData["\<\"a / (b + c)\"\>"], "Output",
    CellLabel -> "Out[2]=", CellID -> 1000030]
}, Open]],

