Cell[CellGroupData[{
Cell["JuliaForm", "ObjectName", CellID -> 1000014],

Cell[TextData[{
    Cell["   ", "ModInfo"],
    Cell[BoxData[
        RowBox[{"JuliaForm", "[", StyleBox["expr", "TI"], "]"}]
    ], "InlineFormula"],
    "\[LineSeparator]displays ",
    Cell[BoxData[StyleBox["expr", "TI"]], "InlineFormula"],
    " as a Julia language expression.",
    "\n",
    Cell["   ", "ModInfo"],
    Cell[BoxData[
        RowBox[{
            "ToString", "[",
            RowBox[{
                RowBox[{
                    "JuliaForm", "[", StyleBox["expr", "TI"], "]"
                }],
                ",", "OutputForm"
            }],
            "]"
        }]
    ], "InlineFormula"],
    "\[LineSeparator]returns the rendered Julia source as a string.",
    "\n",
    Cell["   ", "ModInfo"],
    Cell[BoxData[
        RowBox[{
            "ToString", "[",
            RowBox[{StyleBox["expr", "TI"], ",", "JuliaForm"}],
            "]"
        }]
    ], "InlineFormula"],
    "\[LineSeparator]is a compatibility form that returns the same source string."
}], "Usage", CellID -> 1000015],

Cell[TextData[{
    Cell[BoxData["JuliaForm"], "InlineFormula"],
    " is an output form for individual expressions, not a complete Wolfram Language ",
    "to Julia program translator."
}], "Notes", CellID -> 1000016],

Cell[TextData[{
    "The argument evaluates once according to ordinary Wolfram Language semantics ",
    "before it is rendered. Wrap an expression in ",
    Cell[BoxData[
        ButtonBox["HoldForm",
            BaseStyle -> "Link",
            ButtonData -> "paclet:ref/HoldForm"]
    ], "InlineFormula"],
    " when its arithmetic structure must be retained."
}], "Notes", CellID -> 1000017],

Cell[TextData[{
    "Output is deterministic, single-line UTF-8 source. ",
    Cell[BoxData["JuliaForm"], "InlineFormula"],
    " accepts exactly one argument and has no options."
}], "Notes", CellID -> 1000018],

Cell[TextData[{
    "Unsupported constructs issue ",
    Cell[BoxData[
        RowBox[{"JuliaForm", "::", "unsupported"}]
    ], "InlineFormula"],
    " and return ",
    Cell[BoxData["$Failed"], "InlineFormula"],
    ". Assignments, patterns, scoping constructs, loops, delayed rules, sparse ",
    "arrays, quantities, and rank-three or higher literal lists are intentionally ",
    "rejected. Unsafe mapped-function arities, comparisons whose Julia result ",
    "would change Wolfram semantics, and Eigenvalues are also rejected."
}], "Notes", CellID -> 1000019],

Cell[TextData[{
    "Integers, rationals, complex numbers, and arbitrary-precision real numbers ",
    "retain exactness or explicit precision where Julia provides a faithful ",
    "representation. Exact rational literals use Julia // syntax and are ",
    "parenthesized inside larger multiplicative chains for clarity. Strings ",
    "escape Julia interpolation and control characters."
}], "Notes", CellID -> 1000020],

Cell[TextData[{
    Cell[BoxData["Rule"], "InlineFormula"],
    " renders as a Julia ",
    Cell[BoxData["Pair"], "InlineFormula"],
    ", not as a Wolfram Language replacement rule. Associations render as ",
    Cell[BoxData["Dict"], "InlineFormula"],
    " constructors after strict-key checks; unsafe container keys or key ",
    "collisions fail explicitly."
}], "Notes", CellID -> 1000021],

Cell[TextData[{
    "Unknown symbolic heads render as Julia calls with the same name. The Julia ",
    "environment must define those calls. Mappings such as ",
    Cell[BoxData["Det"], "InlineFormula"],
    " to ",
    Cell[BoxData["det"], "InlineFormula"],
    " require Julia's ",
    Cell[BoxData["LinearAlgebra"], "InlineFormula"],
    " standard library."
}], "Notes", CellID -> 1000022],

Cell[TextData[{
    Cell[BoxData["Part"], "InlineFormula"],
    " emits a self-contained local dispatcher that applies selectors by ",
    "Wolfram dimension, supports regular and ragged arrays, maps ordinal ",
    "selectors to custom Julia axes through scalar indexing, and preserves ",
    "valid empty Span selections. A literal Association retains ordered ",
    "positional selection; an arbitrary runtime Dict accepts only unambiguous ",
    Cell[BoxData[
        RowBox[{"Key", "[", StyleBox["key", "TI"], "]"}]
    ], "InlineFormula"],
    "."
}], "Notes", CellID -> 1000023]
}, Open]],

