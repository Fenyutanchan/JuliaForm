Cell[CellGroupData[{
Cell["属性与关系", "ExampleSection", CellID -> 1000059],

Cell["两种生成字符串的形式等价：", "ExampleText",
    CellID -> 1000060],

Cell[CellGroupData[{
Cell[BoxData[
    RowBox[{
        RowBox[{
            "ToString", "[",
            RowBox[{
                RowBox[{
                    "HoldForm", "[",
                    RowBox[{
                        "a", "/",
