    ], "InlineFormula"],
    "\[NonBreakingSpace]\[FilledVerySmallSquare]\[NonBreakingSpace]",
    Cell[BoxData[
        ButtonBox["ToString",
            BaseStyle -> "Link",
            ButtonData -> "paclet:ref/ToString"]
    ], "InlineFormula"],
    "\[NonBreakingSpace]\[FilledVerySmallSquare]\[NonBreakingSpace]",
    Cell[BoxData[
        ButtonBox["HoldForm",
            BaseStyle -> "Link",
            ButtonData -> "paclet:ref/HoldForm"]
    ], "InlineFormula"],
    "\[NonBreakingSpace]\[FilledVerySmallSquare]\[NonBreakingSpace]",
    Cell[BoxData[
        ButtonBox["Part",
            BaseStyle -> "Link",
            ButtonData -> "paclet:ref/Part"]
    ], "InlineFormula"]
}], "SeeAlso", CellID -> 1000025]
}, Open]],

Cell[CellGroupData[{
Cell["范例", "PrimaryExamplesSection", CellID -> 1000026],

Cell[BoxData[
    RowBox[{"Needs", "[", "\"JuliaForm\:0060\"", "]"}]
], "Input", CellLabel -> "In[1]:=", CellID -> 1000027],

Cell["渲染 held 商并保留其中的括号：", "ExampleText",
    CellID -> 1000028],

Cell[CellGroupData[{
Cell[BoxData[
    RowBox[{
        "ToString", "[",
        RowBox[{
            RowBox[{
                "JuliaForm", "[",
                RowBox[{
                    "HoldForm", "[",
                    RowBox[{
                        "a", "/",
                        RowBox[{"(", RowBox[{"b", "+", "c"}], ")"}]
                    }],
                    "]"
                }],
                "]"
            }],
            ",", "OutputForm"
        }],
        "]"
    }]
], "Input", CellLabel -> "In[2]:=", CellID -> 1000029],
Cell[BoxData["\<\"a / (b + c)\"\>"], "Output",
    CellLabel -> "Out[2]=", CellID -> 1000030]
}, Open]],

Cell["将矩形列表渲染为 Julia 矩阵字面量：", "ExampleText",
    CellID -> 1000031],

Cell[CellGroupData[{
Cell[BoxData[
    RowBox[{
        "ToString", "[",
        RowBox[{
            RowBox[{
                "JuliaForm", "[",
                RowBox[{"{",
                    RowBox[{
                        RowBox[{"{", RowBox[{"1", ",", "2"}], "}"}],
                        ",",
                        RowBox[{"{", RowBox[{"3", ",", "4"}], "}"}]
                    }],
                    "}"
                }],
                "]"
            }],
            ",", "OutputForm"
        }],
        "]"
    }]
], "Input", CellLabel -> "In[3]:=", CellID -> 1000032],
Cell[BoxData["\<\"[1 2; 3 4]\"\>"], "Output",
    CellLabel -> "Out[3]=", CellID -> 1000033]
}, Open]],

Cell["将关联渲染为 Julia 字典构造器：", "ExampleText",
    CellID -> 1000034],

Cell[CellGroupData[{
Cell[BoxData[
    RowBox[{
        "StringQ", "[",
        RowBox[{
            "ToString", "[",
            RowBox[{
                RowBox[{
                    "JuliaForm", "[",
                    RowBox[{"<|",
                        RowBox[{
                            RowBox[{"\"x\"", "\[Rule]", "1"}],
                            ",",
                            RowBox[{
                                "\"y\"", "\[Rule]",
                                RowBox[{"{", RowBox[{"2", ",", "3"}], "}"}]
                            }]
                        }],
                        "|>"
                    }],
                    "]"
                }],
                ",", "OutputForm"
            }],
            "]"
        }],
        "]"
    }]
], "Input", CellLabel -> "In[4]:=", CellID -> 1000035],
Cell[BoxData["True"],
    "Output", CellLabel -> "Out[4]=", CellID -> 1000036]
}, Open]]
}, Open]],

