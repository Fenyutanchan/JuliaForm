Cell[CellGroupData[{
Cell["条件与函数", "ExampleSection", CellID -> 1000045],

Cell["表达式级条件会渲染为 Julia 三元表达式：",
    "ExampleText", CellID -> 1000046],

Cell[CellGroupData[{
Cell[BoxData[
    RowBox[{
        "ToString", "[",
        RowBox[{
            RowBox[{
                "JuliaForm", "[",
                RowBox[{
                    "HoldForm", "[",
                    RowBox[{
                        "If", "[",
                        RowBox[{
                            RowBox[{"x", ">", "0"}],
                            ",", "x", ",",
                            RowBox[{"-", "x"}]
                        }],
                        "]"
                    }],
                    "]"
                }],
                "]"
            }],
            ",", "OutputForm"
        }],
        "]"
    }]
], "Input", CellLabel -> "In[7]:=", CellID -> 1000047],
Cell[BoxData["\<\"x > 0 ? x : -x\"\>"], "Output",
    CellLabel -> "Out[7]=", CellID -> 1000048]
}, Open]],

Cell["映射会处理跨语言的约定差异：", "ExampleText",
    CellID -> 1000049],

Cell[CellGroupData[{
Cell[BoxData[
    RowBox[{
        "ToString", "[",
        RowBox[{
            RowBox[{"JuliaForm", "[",
                RowBox[{"{",
                    RowBox[{
                        RowBox[{"ArcTan", "[", RowBox[{"x", ",", "y"}], "]"}],
                        ",",
                        RowBox[{"Sinc", "[", "x", "]"}],
                        ",",
                        RowBox[{"Quotient", "[", RowBox[{"x", ",", "y"}], "]"}]
                    }],
                    "}"
                }],
                "]"
            }],
            ",", "OutputForm"
        }],
        "]"
    }]
], "Input", CellLabel -> "In[8]:=", CellID -> 1000050],
Cell[BoxData["\<\"[atan(y, x), sinc(x / pi), fld(x, y)]\"\>"], "Output",
    CellLabel -> "Out[8]=", CellID -> 1000051]
}, Open]]
}, Open]],

Cell[CellGroupData[{
