Cell[TextData[{
    Cell[BoxData[
        ButtonBox["CForm",
            BaseStyle -> "Link",
            ButtonData -> "paclet:ref/CForm"]
    ], "InlineFormula"],
    "\[NonBreakingSpace]\[FilledVerySmallSquare]\[NonBreakingSpace]",
