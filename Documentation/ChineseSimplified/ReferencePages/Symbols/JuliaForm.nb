Cell[CellGroupData[{
Cell["JuliaForm", "ObjectName", CellID -> 1000014],

Cell[TextData[{
    Cell["   ", "ModInfo"],
    Cell[BoxData[
        RowBox[{"JuliaForm", "[", StyleBox["expr", "TI"], "]"}]
    ], "InlineFormula"],
    "\[LineSeparator]将 ",
    Cell[BoxData[StyleBox["expr", "TI"]], "InlineFormula"],
    " 显示为 Julia 语言表达式。",
    "\n",
    Cell["   ", "ModInfo"],
    Cell[BoxData[
        RowBox[{
            "ToString", "[",
            RowBox[{
                RowBox[{
                    "JuliaForm", "[", StyleBox["expr", "TI"], "]"
                }],
                ",", "OutputForm"
            }],
            "]"
        }]
    ], "InlineFormula"],
    "\[LineSeparator]以字符串形式返回渲染后的 Julia 源码。",
    "\n",
    Cell["   ", "ModInfo"],
    Cell[BoxData[
        RowBox[{
            "ToString", "[",
            RowBox[{StyleBox["expr", "TI"], ",", "JuliaForm"}],
            "]"
        }]
    ], "InlineFormula"],
    "\[LineSeparator]是兼容形式，返回相同的源码字符串。"
}], "Usage", CellID -> 1000015],

Cell[TextData[{
    Cell[BoxData["JuliaForm"], "InlineFormula"],
    " 是面向单个表达式的输出 Form，而不是完整的 Wolfram Language ",
    "到 Julia 程序转译器。"
}], "Notes", CellID -> 1000016],

Cell[TextData[{
    "参数首先按照普通 Wolfram Language 语义求值一次，",
    "随后才进行渲染。当必须保留算术结构时，请用 ",
    Cell[BoxData[
        ButtonBox["HoldForm",
            BaseStyle -> "Link",
            ButtonData -> "paclet:ref/HoldForm"]
    ], "InlineFormula"],
    " 包裹该表达式。"
}], "Notes", CellID -> 1000017],

Cell[TextData[{
    "输出是确定性的单行 UTF-8 源码。",
    Cell[BoxData["JuliaForm"], "InlineFormula"],
    " 只接受一个参数，并且没有选项。"
}], "Notes", CellID -> 1000018],

Cell[TextData[{
    "不支持的结构会触发 ",
    Cell[BoxData[
        RowBox[{"JuliaForm", "::", "unsupported"}]
    ], "InlineFormula"],
    " 并返回 ",
    Cell[BoxData["$Failed"], "InlineFormula"],
    "。赋值、模式、作用域结构、循环、延迟规则、稀疏",
    "数组、物理量，以及三阶或更高阶的字面量列表会被有意",
    "拒绝。不安全的映射函数参数个数、Julia 结果会改变 Wolfram 语义的比较，",
    "以及 Eigenvalues 也会被拒绝。"
}], "Notes", CellID -> 1000019],

Cell[TextData[{
    "当 Julia 提供忠实表示时，整数、有理数、复数和任意精度实数会",
    "保留精确性或显式精度。字符串会转义 Julia 插值字符和",
    "控制字符。"
}], "Notes", CellID -> 1000020],

Cell[TextData[{
    Cell[BoxData["Rule"], "InlineFormula"],
    " 会渲染为 Julia ",
    Cell[BoxData["Pair"], "InlineFormula"],
    "，而不是 Wolfram Language 替换规则。关联会渲染为 ",
    Cell[BoxData["Dict"], "InlineFormula"],
    " 构造器，但会先检查严格键；不安全的容器键或键冲突会明确失败。"
}], "Notes", CellID -> 1000021],

Cell[TextData[{
    "未知符号头会渲染为同名 Julia 调用。Julia ",
    "环境必须定义这些调用。例如从 ",
    Cell[BoxData["Det"], "InlineFormula"],
    " 到 ",
    Cell[BoxData["det"], "InlineFormula"],
    " 的映射需要 Julia 的 ",
    Cell[BoxData["LinearAlgebra"], "InlineFormula"],
    " 标准库。"
}], "Notes", CellID -> 1000022],

Cell[TextData[{
    Cell[BoxData["Part"], "InlineFormula"],
    " 会生成自包含的局部 dispatcher，按 Wolfram 维度应用选择器，",
    "支持规则与不规则数组，通过 scalar indexing 把序数选择器映射到 Julia ",
    "自定义轴，并保留合法的空 Span。字面 Association 保留有序位置选择；",
    "任意运行时 Dict 只接受无歧义的 ",
    Cell[BoxData[
        RowBox[{"Key", "[", StyleBox["key", "TI"], "]"}]
    ], "InlineFormula"],
    "。"
}], "Notes", CellID -> 1000023]
}, Open]],

